@model AppSettingsModel

<div class="card-body">
    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="AwsS3ConfigModel.Region" />
        </div>
        <div class="col-md-9">
            <nop-editor asp-for="AwsS3ConfigModel.Region" />
            <span asp-validation-for="AwsS3ConfigModel.Region"></span>
        </div>
    </div>
    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="AwsS3ConfigModel.Bucket" />
        </div>
        <div class="col-md-9">
            <nop-editor asp-for="AwsS3ConfigModel.Bucket" />
            <span asp-validation-for="AwsS3ConfigModel.Bucket"></span>
        </div>
    </div>
    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="AwsS3ConfigModel.AccessKeyId" />
        </div>
        <div class="col-md-9">
            <nop-editor asp-for="AwsS3ConfigModel.AccessKeyId" />
            <span asp-validation-for="AwsS3ConfigModel.AccessKeyId"></span>
        </div>
    </div>
    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="AwsS3ConfigModel.SecretAccessKey" />
        </div>
        <div class="col-md-9">
            <nop-editor asp-for="AwsS3ConfigModel.SecretAccessKey" />
            <span asp-validation-for="AwsS3ConfigModel.SecretAccessKey"></span>
        </div>
    </div>
</div>
