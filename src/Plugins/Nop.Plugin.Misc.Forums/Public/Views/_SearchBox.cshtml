<div class="search-box forum-search-box">
    <form asp-route="@ForumDefaults.Routes.Public.BOARDS_SEARCH" method="get">
        <div class="basic">
            <input type="text" class="search-box-text" id="forums-small-searchterms" name="searchterms" placeholder="@T("Plugins.Misc.Forums.SearchForumsTooltip")" />
            <button type="submit" class="button-2 search-box-button">@T("Plugins.Misc.Forums.SearchButton")</button>
        </div>
        <div class="advanced">
            @Html.RouteLink(T("Plugins.Misc.Forums.AdvancedSearch").Text, ForumDefaults.Routes.Public.BOARDS_SEARCH, new { advs = true }, new { title = T("Plugins.Misc.Forums.AdvancedSearch").Text })
        </div>
    </form>
</div>