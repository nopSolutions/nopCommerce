@model ConfigurationModel
@{
    Layout = "_ConfigurePlugin";
    }

<link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons" />
<link rel="stylesheet" href="@Url.Content("~/Plugins/DropShipping.AliExpress/Content/aliexpress-config.css")" />

<form asp-controller="AliExpress" asp-action="Configure" method="post" id="aliexpress-config-root" data-exchange-auth-url="@Url.Action("ExchangeAuthCode", "AliExpress")" data-refresh-token-url="@Url.Action("RefreshToken", "AliExpress")">
    <div class="cards-group">
        <!-- Authentication Section -->
        <div class="card card-default">
            <div class="card-body">
                <div class="aliexpress-section">
                    <h3>
                        <span class="material-icons">vpn_key</span>
                        Authentication Settings
                    </h3>

                    @if (Model.IsTokenValid)
                    {
                        <div class="token-status valid">
                            <span class="material-icons">check_circle</span>
                            <span>Access token is valid. Expires: @Model.AccessTokenExpiresOnUtc?.ToString("yyyy-MM-dd HH:mm") UTC</span>
                        </div>
                    }
                    else
                    {
                        <div class="token-status invalid">
                            <span class="material-icons">error</span>
                            <span>Access token is invalid or expired. Please authorize the application.</span>
                        </div>
                    }

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="AppKey" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="AppKey" />
                            <span asp-validation-for="AppKey"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="AppSecret" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="AppSecret" asp-password="true" />
                            <span asp-validation-for="AppSecret"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="AuthorizationUrl" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="AuthorizationUrl" />
                            <span asp-validation-for="AuthorizationUrl"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="RedirectUri" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="RedirectUri" />
                            <span asp-validation-for="RedirectUri"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="RedirectUriHost" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="RedirectUriHost" />
                            <span asp-validation-for="RedirectUriHost"></span>
                        </div>
                    </div>

                    
                    
                    
                    @if (!string.IsNullOrEmpty(Model.AuthorizationLaunchUrl))
                    {
                        <div class="info-box">
                            <span class="material-icons">info</span>
                            <strong>Authorization Steps:</strong>
                            <ol style="margin: 8px 0 0 32px; padding: 0;">
                                <li>Click the "Authorize with AliExpress" button below</li>
                                <li>Sign in to your AliExpress developer account</li>
                                <li>Approve the authorization request</li>
                                <li>Copy the authorization code from the redirect URL</li>
                                <li>Paste it in the field below and click "Exchange Code for Token"</li>
                            </ol>
                        </div>

                        <div style="margin-bottom: 16px;">
                            <a href="@Model.AuthorizationLaunchUrl" target="_blank" class="auth-button">
                                <span class="material-icons">launch</span>
                                Authorize with AliExpress
                            </a>
                        </div>

                        <div class="form-group row">
                            <div class="col-md-3">
                                <label>Authorization Code</label>
                            </div>
                            <div class="col-md-9">
                                <div class="input-group">
                                    <input type="text" id="authCode" class="form-control" placeholder="Paste authorization code here" />
                                    <div class="input-group-append">
                                        <button type="button" class="btn btn-primary" onclick="exchangeAuthCode()">
                                            <span class="material-icons" style="font-size: 18px; vertical-align: middle;">swap_horiz</span>
                                            Exchange Code
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @if (Model.IsTokenValid)
                    {
                        <div style="margin-top: 16px;">
                            <button type="button" class="btn btn-secondary" onclick="refreshToken()">
                                <span class="material-icons" style="font-size: 18px; vertical-align: middle;">refresh</span>
                                Refresh Token Now
                            </button>
                        </div>
                    }

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="TokenRefreshDaysBeforeExpiry" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="TokenRefreshDaysBeforeExpiry" />
                            <span asp-validation-for="TokenRefreshDaysBeforeExpiry"></span>
                        </div>
                    </div>
                </div>

                <!-- Pricing Settings -->
                <div class="aliexpress-section">
                    <h3>
                        <span class="material-icons">attach_money</span>
                        Pricing & Calculation Settings
                    </h3>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="DefaultMarginPercentage" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="DefaultMarginPercentage" />
                            <span asp-validation-for="DefaultMarginPercentage"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="VatPercentage" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="VatPercentage" />
                            <span asp-validation-for="VatPercentage"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="CustomsDutyPercentage" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="CustomsDutyPercentage" />
                            <span asp-validation-for="CustomsDutyPercentage"></span>
                        </div>
                    </div>

                    <div class="info-box">
                        <span class="material-icons">calculate</span>
                        <strong>Price Calculation Formula:</strong><br/>
                        Final Price = ((Product Price + Import Freight) × (1 + Customs Duty %) + VAT) × (1 + Margin %)
                        Final Selling Price (ex VAT) =
                        ((Product Price + International Shipping)
                        × (1 + Customs Duty %)
                        × (1 + VAT %))
                        × (1 + Margin %)
                        @* <div class="price-simulator"> *@
                        @*     <h4><span class="material-icons">insights</span>Live Profitability Simulator</h4> *@
                        @*     <div class="simulator-grid"> *@
                        @*         <div> *@
                        @*             <label>Product Price (R)</label> *@
                        @*             <input type="number" id="simProductPrice" value="100" min="0" step="0.01" /> *@
                        @*         </div> *@
                        @*         <div> *@
                        @*             <label>Import Freight (R)</label> *@
                        @*             <input type="number" id="simFreight" value="25" min="0" step="0.01" /> *@
                        @*         </div> *@
                        @*         <div> *@
                        @*             <label>International Shipping (R)</label> *@
                        @*             <input type="number" id="simShipping" value="40" min="0" step="0.01" /> *@
                        @*         </div> *@
                        @*         <div> *@
                        @*             <label>Customs Duty (%)</label> *@
                        @*             <input type="number" id="simCustoms" value="15" min="0" step="0.1" /> *@
                        @*         </div> *@
                        @*         <div> *@
                        @*             <label>VAT (%)</label> *@
                        @*             <input type="number" id="simVat" value="15" min="0" step="0.1" /> *@
                        @*         </div> *@
                        @*         <div> *@
                        @*             <label>Margin (%)</label> *@
                        @*             <input type="number" id="simMargin" value="30" min="0" step="0.1" /> *@
                        @*         </div> *@
                        @*     </div> *@
                        @*     <div class="simulator-metrics"> *@
                        @*         <div class="metric-chip"> *@
                        @*             <span>Final Selling Price</span> *@
                        @*             <strong id="simFinalPrice">R0.00</strong> *@
                        @*         </div> *@
                        @*         <div class="metric-chip"> *@
                        @*             <span>Unit Profit</span> *@
                        @*             <strong id="simProfit">R0.00</strong> *@
                        @*         </div> *@
                        @*         <div class="metric-chip"> *@
                        @*             <span>ROI</span> *@
                        @*             <strong id="simRoi">0%</strong> *@
                        @*         </div> *@
                        @*         <div class="metric-chip"> *@
                        @*             <span>Profit Health</span> *@
                        @*             <strong id="simHealth">-</strong> *@
                        @*         </div> *@
                        @*     </div> *@
                        @*     <div id="priceSimulatorChart"></div> *@
                        @* </div> *@
                    </div>
                </div>

                <!-- Regional Settings -->
                <div class="aliexpress-section">
                    <h3>
                        <span class="material-icons">public</span>
                        Regional Settings
                    </h3>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="DefaultShippingCountry" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="DefaultShippingCountry" />
                            <span asp-validation-for="DefaultShippingCountry"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="DefaultCurrency" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="DefaultCurrency" />
                            <span asp-validation-for="DefaultCurrency"></span>
                        </div>
                    </div>
                </div>

                <!-- Automation Settings -->
                <div class="aliexpress-section">
                    <h3>
                        <span class="material-icons">settings_suggest</span>
                        Automation Settings
                    </h3>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="EnableDailySync" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="EnableDailySync" />
                            <span asp-validation-for="EnableDailySync"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="DailySyncHour" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="DailySyncHour" />
                            <span asp-validation-for="DailySyncHour"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="AutoCreateOrders" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="AutoCreateOrders" />
                            <span asp-validation-for="AutoCreateOrders"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="AutoCreateLocalShipments" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="AutoCreateLocalShipments" />
                            <span asp-validation-for="AutoCreateLocalShipments"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="UseSandbox" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="UseSandbox" />
                            <span asp-validation-for="UseSandbox"></span>
                        </div>
                    </div>
                </div>

                <div class="card-footer">
                    <button type="submit" name="save" class="btn btn-primary">
                        <span class="material-icons" style="font-size: 18px; vertical-align: middle;">save</span>
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

<script src="https://code.highcharts.com/highcharts.js"></script>
<script src="@Url.Content("~/Plugins/DropShipping.AliExpress/Content/aliexpress-config.js")"></script>
