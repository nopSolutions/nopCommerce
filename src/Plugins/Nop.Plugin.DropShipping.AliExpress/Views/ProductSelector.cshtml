@model ProductSelectorModel

<link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons" />
<link rel="stylesheet" href="@Url.Content("~/Plugins/DropShipping.AliExpress/Content/aliexpress-product-selector.css")" />

<div class="aliexpress-product-selector" data-product-id="@Model.ProductId" data-search-url="@Url.Action("SearchProducts", "AliExpress", new { area = "Admin" })" data-default-image="@Url.Content("~/images/default-image.png")">
    <h4>
        <span class="material-icons">shopping_bag</span>
        AliExpress Product Selection
    </h4>

    <div id="aliexpressSelectedProduct" style="display: none;">
        <div class="aliexpress-selected-product">
            <img id="aliexpressSelectedImage" src="" alt="Product">
            <div class="aliexpress-selected-product-info">
                <div class="aliexpress-selected-product-title" id="aliexpressSelectedTitle"></div>
                <div class="aliexpress-selected-product-price" id="aliexpressSelectedPrice"></div>
                <small class="text-muted">ID: <span id="aliexpressSelectedId"></span></small>
            </div>
            <button type="button" class="aliexpress-btn aliexpress-btn-secondary" data-action="remove-product">
                <span class="material-icons">delete</span>
                Remove
            </button>
        </div>
    </div>

    <div id="aliexpressNoSelection">
        <p class="text-muted">No AliExpress product selected for this product.</p>
    </div>

    <button type="button" class="aliexpress-btn" data-action="open-search">
        <span class="material-icons">search</span>
        Search AliExpress Products
    </button>

    <input type="hidden" id="aliexpressProductId" name="AliExpressProductId" value="@Model.AliExpressProductId">
    <input type="hidden" id="aliexpressProductData" name="AliExpressProductData" value="">
</div>

<!-- Search Modal -->
<div id="aliexpressSearchModal" class="aliexpress-search-modal">
    <div class="aliexpress-search-modal-content">
        <div class="aliexpress-search-modal-header">
            <h3>
                <span class="material-icons" style="margin-right: 8px; color: #FF6A00;">search</span>
                Search AliExpress Products
            </h3>
            <button class="aliexpress-close-btn" data-action="close-search">
                <span class="material-icons">close</span>
            </button>
        </div>
        <div class="aliexpress-search-modal-body">
            <div class="aliexpress-search-box">
                <input type="text" id="aliexpressSearchKeyword" placeholder="Enter search keyword...">
                <button data-action="search-products">
                    <span class="material-icons">search</span>
                    Search
                </button>
            </div>
            <div id="aliexpressSearchResults" class="aliexpress-search-results"></div>
            <div id="aliexpressSearchLoading" class="aliexpress-loading" style="display: none;">
                <span class="material-icons" style="font-size: 48px; color: #FF6A00;">hourglass_empty</span>
                <p>Searching AliExpress...</p>
            </div>
        </div>
    </div>
</div>

<script src="@Url.Content("~/Plugins/DropShipping.AliExpress/Content/aliexpress-product-selector.js")"></script>
