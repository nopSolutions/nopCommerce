@model string
@{
    Layout = "";
}

<!DOCTYPE html>
<html>
<head>
    <title>Payment Complete</title>
    <script>
        // Close popup and redirect parent
        if (window.opener) {
            window.opener.location.href = '@Model';
            window.close();
        } else {
            window.location.href = '@Model';
        }
    </script>
</head>
<body>
    <div style="text-align: center; padding: 50px; font-family: Arial, sans-serif;">
        <h2>Payment Processing Complete</h2>
        <p>Redirecting you to your order...</p>
        <p><a href="@Model">Click here if you are not redirected automatically</a></p>
    </div>
</body>
</html>