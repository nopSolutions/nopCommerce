@model string
@{
    Layout = "";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@T("Checkout.OrderPlaced")</title>
</head>
<body>
    <p>@T("Checkout.OrderPlaced")</p>
    <div id="paystack-redirect" data-url="@Model"></div>
    <script>
        (function () {
            var el = document.getElementById('paystack-redirect');
            var redirectUrl = el ? el.getAttribute('data-url') : '';
            if (window.opener && redirectUrl) {
                window.opener.location.href = redirectUrl;
            }
            window.close();
        })();
    </script>
</body>
</html>
